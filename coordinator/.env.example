# Coordinator Band credentials (agent key, band_a_...)
# The bridge connects to Band as the coordinator agent with these.
COORDINATOR_AGENT_ID=
COORDINATOR_API_KEY=

# Human user key (band_u_...) — used only by setup_session.py to build the
# session and add participants. Not used at runtime by the bridge.
BAND_USER_KEY=

# The one shared session room. Run setup_session.py to create it, then paste
# the printed SESSION_ROOM_ID here.
SESSION_ROOM_ID=
